# ============================================================
# BlindVault 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 加密 ----
# 32 字节 AES-256 密钥，base64 编码
# 生成方法: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
BLINDVAULT_ENCRYPTION_KEY=

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=blindvault:

# ---- LLM ----
# 支持 openai / mock
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=

# ---- 应用 ----
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
BLINDVAULT_SANDBOX_URL=http://sandbox:8001
