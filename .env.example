# ============================================================
# BlindVault 环境变量模板
# 复制此文件为 .env 并填入实际值（推荐直接用 ./install.sh 自动生成）
# ============================================================

# ---- 加密 ----
# 32 字节 AES-256 密钥，base64 编码（首次运行后请勿更改，否则已存凭证无法解密）
# 生成方法: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
BLINDVAULT_ENCRYPTION_KEY=

# ---- LLM 网关（LiteLLM）----
# API key 只在此处维护，绝不在任何 API/UI 暴露或修改（安全铁律 6）
BLINDVAULT_LITELLM_BASE_URL=https://your-litellm-gateway/v1
BLINDVAULT_LITELLM_API_KEY=
BLINDVAULT_DEFAULT_MODEL=gpt-4o
# BLINDVAULT_MAX_ITERATIONS=15

# ---- Redis（需 Redis Stack，含 RedisJSON + RediSearch）----
# docker-compose 内部用 redis://redis:6379/0；本地手动开发用 redis://localhost:6379/0
BLINDVAULT_REDIS_URL=redis://redis:6379/0

# ---- 沙箱执行器（fail-closed：为空则拒绝执行命令）----
BLINDVAULT_SANDBOX_URL=http://sandbox:8001

# ---- PostgreSQL 归档（为空则不启用归档）----
PG_PASSWORD=blindvault_default_pg_pass
BLINDVAULT_DATABASE_URL=postgresql://blindvault:blindvault_default_pg_pass@postgres:5432/blindvault

# ---- 企业版（可选）----
# 设置后解锁本地模型语义脱敏网关
# BLINDVAULT_EE_LICENSE=

# ---- 端口（docker-compose 用）----
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ---- 构建镜像源（true=国内清华/淘宝源加速；海外部署设 false）----
USE_CN_MIRROR=true

# ---- 日志 ----
BLINDVAULT_LOG_LEVEL=INFO
